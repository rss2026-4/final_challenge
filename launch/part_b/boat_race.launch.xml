<launch>

  <node pkg="final_challenge" exec="astar_planner" name="astar_planner" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="homography_transform" name="homography_transform" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="map_inflator" name="map_inflator" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="motion_model" name="motion_model" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="parking_controller" name="parking_controller" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="parking_detector" name="parking_detector" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="particle_filter" name="particle_filter" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="pedestrians" name="pedestrians" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="safety_controller" name="safety_controller" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="sensor_model" name="sensor_model" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="traffic_light" name="traffic_light" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="trajectory_builder" name="trajectory_builder" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="trajectory_follower" name="trajectory_follower" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="trajectory_loader" name="trajectory_loader" output="screen">
    <param from="$(find-pkg-share final_challenge)/config/part_b/params.yaml"/>
  </node>

  <node pkg="final_challenge" exec="yolo_annotator" name="yolo_annotator" output="screen">
    <param name="model" value="yolo11n.pt" />
    <param name="conf_threshold" value="0.5" />
    <param name="iou_threshold" value="0.7" />
  </node>


  
</launch>